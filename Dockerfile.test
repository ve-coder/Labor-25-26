# Wir nutzen die schlanke Debian Bookworm Basis
FROM debian:bookworm-slim

WORKDIR /app

# 1. Raspberry Pi Paketquellen hinzufügen (WICHTIG für libcamera!)
RUN apt-get update && apt-get install -y --no-install-recommends wget gnupg && \
    wget -qO - https://archive.raspberrypi.org/debian/raspberrypi.gpg.key | gpg --dearmor -o /usr/share/keyrings/raspi.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/raspi.gpg] http://archive.raspberrypi.org/debian/ bookworm main" > /etc/apt/sources.list.d/raspi.list

# 2. Alle System-Pakete installieren (picamera2 und libcamera laden wir hier!)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    python3-picamera2 \
    python3-libcamera \
    python3-kms++ \
    build-essential \
    libcap-dev \
    cmake \
    libatlas-base-dev \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# 3. Python-Umgebung erstellen, die System-Pakete einbindet
RUN python3 -m venv --system-site-packages /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 4. Pip-Pakete installieren (OHNE picamera2, das ist schon im System!)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir \
    numpy==1.24.3 \
    opencv-python-headless==4.8.1.78 \
    kociemba==1.2.1

COPY . .

# Falls dein Skript anders heißt als main.py, hier anpassen!
CMD ["python", "main.py"]
