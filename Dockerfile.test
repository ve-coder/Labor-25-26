FROM arm64v8/python:3.11-slim-bullseye

WORKDIR /app
ENV PYTHONPATH=/usr/lib/python3/dist-packages:$PYTHONPATH
# Essenzielle Build-Tools + OpenCV Dependencies (Bullseye hat alle Packages)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcap-dev \
    build-essential \
    cmake \
    git \
    wget \
    libatlas-base-dev \
    libtiff-dev \
    libharfbuzz0b \
    libwebp6 \
    libtiff5 \
    libopenjp2-7 \
    libegl1 \
    libx11-6 \
    libxrandr2 \
    libdrm2 \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Python Dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir \
    numpy==1.24.3 \
    opencv-python-headless==4.8.1.78 \
    kociemba==1.2.1 \
    picamera2==0.3.2

COPY . .

# Test-Modus für Kamera ohne GUI
ENV TEST_MODE=1
ENV PYTHONUNBUFFERED=1

CMD ["python", "kombidings_test.py"]

